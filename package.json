{
  "name": "image-creator",
  "version": "0.1.0",
  "private": true,
  "description": "Batch image crop and export desktop tool.",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "pnpm build:main && node scripts/dev-electron.cjs",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "pnpm typecheck && pnpm test && pnpm build:main && vite build",
    "dist": "pnpm build && electron-builder --win dir --x64",
    "preview": "vite preview",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "build": {
    "appId": "com.luc1ferase.imagecreator",
    "productName": "Image Creator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "packageManager": "pnpm@10.28.0"
}
